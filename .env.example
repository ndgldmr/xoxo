# LLM Configuration
# Get Gemini API key from: https://aistudio.google.com/apikey
# Get OpenAI API key from: https://platform.openai.com/api-keys

# For Google Gemini (recommended - free tier available):
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-flash-latest
LLM_BASE_URL=https://generativelanguage.googleapis.com
LLM_TIMEOUT=60

# For OpenAI:
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# WaSenderAPI Configuration
# Get your API key from: https://wasenderapi.com
WASENDER_API_KEY=your_wasender_api_key_here
WASENDER_WEBHOOK_SECRET=your_webhook_secret_here  # From WaSenderAPI dashboard → Webhook Secret

# Database Configuration (enables multi-recipient mode)
# If set, sends to all students in the database
# For local development (SQLite):
# DATABASE_URL=sqlite:///./xoxo.db
# For Supabase PostgreSQL (production):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# API Authentication (required in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here

# GCP Cloud Scheduler (production-only; leave blank for local dev)
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=us-central1
GCP_SCHEDULER_JOB_ID=xoxo-daily-send
SERVICE_URL=https://your-cloud-run-service-url

# Application Settings
DRY_RUN=true  # Set to false to actually send messages
AUDIT_LOG_PATH=audit_log.jsonl
SEND_DELAY_SECONDS=0.5  # Delay between sends in multi-recipient mode
