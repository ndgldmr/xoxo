# ==============================================
# XOXO Education Backend - Environment Variables
# ==============================================
# Copy this file to .env and update with your values

# ==============================================
# Application Settings
# ==============================================
APP_NAME=XOXO Education API
ENVIRONMENT=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO

# ==============================================
# Server Configuration
# ==============================================
HOST=0.0.0.0
PORT=8000

# ==============================================
# Database Configuration
# ==============================================
# Local development (Docker Compose)
DATABASE_URL=postgresql+asyncpg://xoxo:xoxo@localhost:5432/xoxo_dev

# Production example (update with your credentials)
# DATABASE_URL=postgresql+asyncpg://username:password@hostname:5432/database_name

DB_ECHO=False  # Set to True to see SQL queries in logs
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==============================================
# CORS Configuration
# ==============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================================
# Security
# ==============================================
# Generate a secure random key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==============================================
# API Versioning
# ==============================================
API_V1_PREFIX=/api/v1

# ==============================================
# AI Configuration (Message Generation)
# ==============================================
# Provider: mock (default, no API key needed), openai, openrouter
AI_PROVIDER=mock

# Model identifier
# OpenAI: gpt-4o-mini, gpt-3.5-turbo, gpt-4, gpt-4-turbo
# OpenRouter: anthropic/claude-3-haiku, google/gemini-pro, meta-llama/llama-3-8b, etc.
AI_MODEL=gpt-4o-mini

# API Keys (leave empty if using mock provider)
# Get keys from: https://platform.openai.com/api-keys or https://openrouter.ai/keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Generation settings (optional, defaults shown)
AI_MAX_RETRIES=1
AI_TIMEOUT=30.0
AI_MAX_TOKENS=500
